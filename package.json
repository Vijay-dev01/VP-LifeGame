{
  "name": "lifegame-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "npx cross-env EAS_NO_VCS=1 eas build --platform android --profile production",
    "build:ios": "npx cross-env EAS_NO_VCS=1 eas build --platform ios --profile production",
    "build:preview": "npx cross-env EAS_NO_VCS=1 eas build --platform android --profile preview"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "date-fns": "^4.1.0",
    "expo": "~55.0.6",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-mail-composer": "^55.0.9",
    "expo-print": "^55.0.9",
    "expo-router": "~55.0.6",
    "expo-sharing": "^55.0.14",
    "expo-splash-screen": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.2",
    "cross-env": "^7.0.3",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@react-native-async-storage/async-storage": "2.2.0"
  },
  "private": true
}
