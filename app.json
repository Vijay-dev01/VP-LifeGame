{
  "expo": {
    "name": "VPRIME",
    "slug": "vprime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./VP.jpg",
    "scheme": "vprime",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./VP.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vprime.app"
    },
    "android": {
      "package": "com.vprime.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./VP.jpg"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8430a49d-d1d1-4382-bb94-50286a597d2e"
      }
    }
  }
}
