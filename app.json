{
  "expo": {
    "name": "VPRIME",
    "slug": "vprime",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./VP.png",
    "scheme": "vprime",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./VP.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vprime.app"
    },
    "android": {
      "package": "com.vprime.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./VP.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 34
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed1e302e-ca42-4b22-ac03-6c6c6889ab28"
      }
    },
    "owner": "vijayganesh"
  }
}
